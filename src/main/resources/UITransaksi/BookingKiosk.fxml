<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="ProjekAstra.Controller.Transaksi.BookingKiosk"
      styleClass="detail-bubble" alignment="CENTER" spacing="12"
      maxWidth="440" maxHeight="650" prefWidth="440">

    <padding><Insets top="35" bottom="30" left="35" right="35"/></padding>

    <Label text="Form Booking Villa" styleClass="detail-title"/>
    <Label fx:id="lblVillaTerpilih" styleClass="detail-sub" wrapText="true"/>

    <Label text="Pilih Penyewa" styleClass="detail-label-kecil"/>
    <ComboBox fx:id="cbPenyewa" styleClass="input-field" maxWidth="Infinity" promptText="Pilih penyewa..."/>

    <Label text="Alamat" styleClass="detail-label-kecil"/>
    <TextArea fx:id="txtAlamat" styleClass="input-field" prefHeight="50" wrapText="true"/>

    <HBox spacing="12">
        <VBox spacing="4" HBox.hgrow="ALWAYS">
            <Label text="Check-In" styleClass="detail-label-kecil"/>
            <DatePicker fx:id="dpCheckin" styleClass="input-field" maxWidth="Infinity"/>
        </VBox>
        <VBox spacing="4" HBox.hgrow="ALWAYS">
            <Label text="Check-Out" styleClass="detail-label-kecil"/>
            <DatePicker fx:id="dpCheckout" styleClass="input-field" maxWidth="Infinity"/>
        </VBox>
    </HBox>

    <Label text="Jumlah Tamu" styleClass="detail-label-kecil"/>
    <TextField fx:id="txtJumlahTamu" styleClass="input-field"/>

    <Label text="Catatan (opsional)" styleClass="detail-label-kecil"/>
    <TextArea fx:id="txtCatatan" styleClass="input-field" prefHeight="45" wrapText="true"/>

    <Label fx:id="lblGrandHarga" styleClass="detail-harga"/>

    <Region VBox.vgrow="ALWAYS"/>

    <HBox spacing="15" alignment="CENTER">
        <Button text="⬅ Kembali" onAction="#handleKembali" styleClass="btn-kembali" prefWidth="150"/>
        <Button text="📖 Booking Sekarang" onAction="#handleBookingSekarang" styleClass="btn-booking" prefWidth="180"/>
    </HBox>
</VBox>