<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="ProjekAstra.Controller.Dashboard.DashboardPenyewa"
            styleClass="bg-soft"
            stylesheets="@../css/villa-theme.css">

    <top>
        <HBox alignment="CENTER_LEFT" prefHeight="70" styleClass="topbar">
            <padding><Insets left="25" right="25"/></padding>
            <Label fx:id="lblJudul" text="Dashboard" styleClass="page-title">
                <font><Font name="System Bold" size="18"/></font>
            </Label>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="Keluar" onAction="#handleLogout" prefHeight="35" prefWidth="90"
                    styleClass="btn-danger"/>
        </HBox>
    </top>

    <center>
        <StackPane fx:id="contentPane">

            <!-- ===== LAYAR 1: Grid bubble villa + search ===== -->
            <VBox fx:id="mainView" spacing="20" alignment="TOP_CENTER" styleClass="kiosk-main">
                <padding><Insets top="25" bottom="15" left="30" right="30"/></padding>

                <Label text="🏡 Pilih Villa Kamu 🏡" styleClass="welcome-text" style="-fx-font-size: 20px;"/>

                <HBox spacing="10" alignment="CENTER_LEFT" styleClass="search-bar" maxWidth="Infinity">
                    <TextField fx:id="txtCari" promptText="Cari nama villa atau kapasitas (mis. 6)"
                               prefWidth="380" styleClass="search-field"/>
                    <Button text="🔍 Cari" onAction="#handleCari" styleClass="btn-search"/>
                    <Button text="✖ Reset" onAction="#handleResetCari" styleClass="btn-reset"/>
                </HBox>

                <ScrollPane fitToWidth="true" styleClass="bubble-scroll" VBox.vgrow="ALWAYS">
                    <FlowPane fx:id="bubbleContainer" hgap="28" vgap="28" alignment="CENTER" styleClass="bubble-flow">
                        <padding><Insets top="15" bottom="30"/></padding>
                    </FlowPane>
                </ScrollPane>
            </VBox>

            <!-- ===== LAYAR 2: Overlay (detail villa / form booking / hasil booking) ===== -->
            <StackPane fx:id="overlayPane" styleClass="overlay-dim" visible="false" managed="false">

                <!-- BUBBLE 1: Detail villa -->
                <VBox fx:id="detailBubble" styleClass="detail-bubble" alignment="CENTER" spacing="10"
                      maxWidth="440" maxHeight="620" prefWidth="440">
                    <padding><Insets top="35" bottom="30" left="35" right="35"/></padding>

                    <Label fx:id="lblDetailStatus" styleClass="detail-status-badge"/>
                    <Label fx:id="lblDetailNama" styleClass="detail-title"/>
                    <Label fx:id="lblDetailKategori" styleClass="detail-sub"/>
                    <Label fx:id="lblDetailKapasitas" styleClass="detail-sub"/>
                    <Label fx:id="lblDetailHarga" styleClass="detail-harga"/>

                    <Separator/>

                    <Label text="Alamat:" styleClass="detail-label-kecil"/>
                    <Label fx:id="lblDetailAlamat" styleClass="detail-desc" wrapText="true"/>

                    <Label text="Pemilik:" styleClass="detail-label-kecil"/>
                    <Label fx:id="lblDetailPemilik" styleClass="detail-desc"/>

                    <Label text="Fasilitas:" styleClass="detail-label-kecil"/>
                    <FlowPane fx:id="fasilitasContainer" hgap="8" vgap="8" styleClass="fasilitas-flow"/>

                    <Region VBox.vgrow="ALWAYS"/>

                    <HBox spacing="15" alignment="CENTER">
                        <Button text="⬅ Kembali" onAction="#handleKembaliBubble" styleClass="btn-kembali" prefWidth="150"/>
                        <Button text="📖 Booking" onAction="#handleBooking" styleClass="btn-booking" prefWidth="150"/>
                    </HBox>
                </VBox>

                <!-- BUBBLE 2: Form booking (langsung inline, tanpa fx:include) -->
                <VBox fx:id="bookingPane" styleClass="detail-bubble" alignment="CENTER" spacing="12"
                      maxWidth="440" maxHeight="650" prefWidth="440" visible="false" managed="false">

                    <padding><Insets top="35" bottom="30" left="35" right="35"/></padding>

                    <Label text="Form Booking Villa" styleClass="detail-title"/>
                    <Label fx:id="lblVillaTerpilih" styleClass="detail-sub" wrapText="true"/>

                    <Label text="Pilih Penyewa" styleClass="detail-label-kecil"/>
                    <ComboBox fx:id="cbPenyewa" styleClass="input-field" maxWidth="Infinity" promptText="Pilih penyewa..."/>

                    <Label text="Alamat" styleClass="detail-label-kecil"/>
                    <TextArea fx:id="txtAlamatBooking" styleClass="input-field" prefHeight="50" wrapText="true"/>

                    <HBox spacing="12">
                        <VBox spacing="4" HBox.hgrow="ALWAYS">
                            <Label text="Check-In" styleClass="detail-label-kecil"/>
                            <DatePicker fx:id="dpCheckin" styleClass="input-field" maxWidth="Infinity"/>
                        </VBox>
                        <VBox spacing="4" HBox.hgrow="ALWAYS">
                            <Label text="Check-Out" styleClass="detail-label-kecil"/>
                            <DatePicker fx:id="dpCheckout" styleClass="input-field" maxWidth="Infinity"/>
                        </VBox>
                    </HBox>

                    <Label text="Jumlah Tamu" styleClass="detail-label-kecil"/>
                    <TextField fx:id="txtJumlahTamu" styleClass="input-field"/>

                    <Label text="Catatan (opsional)" styleClass="detail-label-kecil"/>
                    <TextArea fx:id="txtCatatan" styleClass="input-field" prefHeight="45" wrapText="true"/>

                    <Label fx:id="lblGrandHarga" styleClass="detail-harga"/>

                    <Region VBox.vgrow="ALWAYS"/>

                    <HBox spacing="15" alignment="CENTER">
                        <Button text="⬅ Kembali" onAction="#handleKembaliBooking" styleClass="btn-kembali" prefWidth="150"/>
                        <Button text="📖 Booking Sekarang" onAction="#handleBookingSekarang" styleClass="btn-booking" prefWidth="180"/>
                    </HBox>
                </VBox>

                <!-- BUBBLE 3: Popup hasil booking (pengganti Alert) -->
                <VBox fx:id="resultBubble" styleClass="detail-bubble" alignment="CENTER" spacing="16"
                      maxWidth="400" prefWidth="400" maxHeight="360" prefHeight="360"
                      visible="false" managed="false">
                    <padding><Insets top="34" bottom="30" left="30" right="30"/></padding>

                    <Label text="✅" style="-fx-font-size: 42px;"/>
                    <Label text="Booking Berhasil!" styleClass="detail-title"/>
                    <Label text="Catat / tunjukkan kode ini ke resepsionis saat check-in:"
                           styleClass="detail-sub" wrapText="true" textAlignment="CENTER"/>
                    <Label fx:id="lblKodeBooking" styleClass="detail-harga" style="-fx-font-size: 26px;"/>

                    <Button text="Tutup" styleClass="btn-booking" onAction="#handleTutupResult" maxWidth="Infinity"/>
                </VBox>

            </StackPane>

        </StackPane>
    </center>

</BorderPane>