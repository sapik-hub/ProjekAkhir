<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="ProjekAstra.Controller.Dashboard.DashboardPenyewa"
            styleClass="bg-soft"
            stylesheets="@../css/villa-theme.css">

    <top>
        <HBox alignment="CENTER_LEFT" prefHeight="70" styleClass="topbar">
            <padding><Insets left="25" right="25"/></padding>
            <Label fx:id="lblJudul" text="Dashboard" styleClass="page-title">
                <font><Font name="System Bold" size="18"/></font>
            </Label>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="Keluar" onAction="#handleLogout" prefHeight="35" prefWidth="90"
                    styleClass="btn-danger"/>
        </HBox>
    </top>

    <center>
        <StackPane fx:id="contentPane">

            <!-- ===== LAYAR 1: Grid bubble villa + search ===== -->
            <VBox fx:id="mainView" spacing="20" alignment="TOP_CENTER" styleClass="kiosk-main">
                <padding><Insets top="25" bottom="15" left="30" right="30"/></padding>

                <Label text="🏡 Pilih Villa Kamu 🏡" styleClass="welcome-text" style="-fx-font-size: 20px;"/>

                <HBox spacing="10" alignment="CENTER_LEFT" styleClass="search-bar" maxWidth="Infinity">
                    <TextField fx:id="txtCari" promptText="Cari nama villa atau kapasitas (mis. 6)"
                               prefWidth="380" styleClass="search-field"/>
                    <Button text="🔍 Cari" onAction="#handleCari" styleClass="btn-search"/>
                    <Button text="✖ Reset" onAction="#handleResetCari" styleClass="btn-reset"/>
                </HBox>

                <ScrollPane fitToWidth="true" styleClass="bubble-scroll" VBox.vgrow="ALWAYS">
                    <FlowPane fx:id="bubbleContainer" hgap="28" vgap="28" alignment="CENTER" styleClass="bubble-flow">
                        <padding><Insets top="15" bottom="30"/></padding>
                    </FlowPane>
                </ScrollPane>
            </VBox>

            <!-- ===== LAYAR 2: Overlay bubble detail / transaksi ===== -->
            <StackPane fx:id="overlayPane" styleClass="overlay-dim" visible="false" managed="false">
                <VBox fx:id="detailBubble" styleClass="detail-bubble" alignment="CENTER" spacing="10"
                      maxWidth="440" maxHeight="620" prefWidth="440">
                    <padding><Insets top="35" bottom="30" left="35" right="35"/></padding>

                    <Label fx:id="lblDetailStatus" styleClass="detail-status-badge"/>
                    <Label fx:id="lblDetailNama" styleClass="detail-title"/>
                    <Label fx:id="lblDetailKategori" styleClass="detail-sub"/>
                    <Label fx:id="lblDetailKapasitas" styleClass="detail-sub"/>
                    <Label fx:id="lblDetailHarga" styleClass="detail-harga"/>

                    <Separator/>

                    <Label text="Alamat:" styleClass="detail-label-kecil"/>
                    <Label fx:id="lblDetailAlamat" styleClass="detail-desc" wrapText="true"/>

                    <Label text="Pemilik:" styleClass="detail-label-kecil"/>
                    <Label fx:id="lblDetailPemilik" styleClass="detail-desc"/>

                    <Label text="Fasilitas:" styleClass="detail-label-kecil"/>
                    <FlowPane fx:id="fasilitasContainer" hgap="8" vgap="8" styleClass="fasilitas-flow"/>

                    <Region VBox.vgrow="ALWAYS"/>

                    <HBox spacing="15" alignment="CENTER">
                        <Button text="⬅ Kembali" onAction="#handleKembaliBubble" styleClass="btn-kembali" prefWidth="150"/>
                        <Button text="📖 Booking" onAction="#handleBooking" styleClass="btn-booking" prefWidth="150"/>
                    </HBox>
                </VBox>
            </StackPane>

        </StackPane>
    </center>

</BorderPane>