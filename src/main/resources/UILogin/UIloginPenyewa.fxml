<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>


<StackPane xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="ProjekAstra.Controller.Login.LoginPenyewa"
           styleClass="bg-hero"
           stylesheets="@../css/villa-theme.css">

    <VBox alignment="CENTER"
          spacing="20"
          maxWidth="420">

        <VBox alignment="CENTER"
              spacing="20"
              prefWidth="400"
              styleClass="card">

            <padding>
                <Insets top="30" bottom="30" left="35" right="35"/>
            </padding>

            <Label text="🏠 VillaNesia 🌸"
                   styleClass="brand-title">
                <font>
                    <Font name="System Bold" size="28"/>
                </font>
            </Label>

            <Label text="Akun Penyewa"
                   styleClass="brand-subtitle"/>

            <!-- Toggle Tab -->
            <HBox spacing="0"
                  prefHeight="40"
                  styleClass="tab-bar">

                <Button fx:id="tabLogin"
                        text="Masuk"
                        prefWidth="190"
                        onAction="#showLogin"
                        styleClass="tab-btn-active"/>

                <Button fx:id="tabRegister"
                        text="Daftar"
                        prefWidth="190"
                        onAction="#showRegister"
                        styleClass="tab-btn-inactive"/>

            </HBox>

            <!-- LOGIN -->
            <VBox fx:id="paneLogin"
                  spacing="12">

                <TextField fx:id="loginUsername"
                           promptText="Username"
                           styleClass="input-field"/>

                <PasswordField fx:id="loginPassword"
                               promptText="Password"
                               styleClass="input-field"/>

                <HBox spacing="10">

                    <Button text="← Kembali"
                            prefWidth="100"
                            onAction="#handleKembali"
                            styleClass="btn-outline"/>

                    <Button text="Masuk 🌺"
                            onAction="#handleLogin"
                            HBox.hgrow="ALWAYS"
                            maxWidth="Infinity"
                            styleClass="btn-primary"/>

                </HBox>

            </VBox>

            <!-- REGISTER -->
            <VBox fx:id="paneRegister"
                  spacing="12"
                  visible="false"
                  managed="false">

                <TextField fx:id="regNama"
                           promptText="Nama Lengkap"
                           styleClass="input-field"/>

                <TextField fx:id="regNoTelp"
                           promptText="No. Telepon"
                           styleClass="input-field"/>

                <TextField fx:id="regNikKtp"
                           promptText="NIK KTP"
                           styleClass="input-field"
                           onKeyTyped="#handleNikOnlyNumber"/>

                <DatePicker fx:id="regTglLahir"
                            promptText="Tanggal Lahir"
                            prefWidth="330"
                            styleClass="input-field"/>

                <TextField fx:id="regAlamat"
                           promptText="Alamat"
                           styleClass="input-field"/>

                <TextField fx:id="regUsername"
                           promptText="Username"
                           styleClass="input-field"/>

                <PasswordField fx:id="regPassword"
                               promptText="Password"
                               styleClass="input-field"/>

                <Button text="Daftar 🏖️"
                        prefWidth="330"
                        onAction="#handleRegister"
                        styleClass="btn-primary"/>

            </VBox>
        </VBox>

    </VBox>

</StackPane>