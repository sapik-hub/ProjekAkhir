<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="ProjekAstra.Controller.Master.CrudKaryawan"
            styleClass="bg-soft"
            stylesheets="@../css/villa-theme.css">

    <center>
        <HBox spacing="15">
            <padding><Insets top="0" bottom="15" left="0" right="0"/></padding>

            <!-- FORM INPUT -->
            <VBox spacing="12" prefWidth="280" styleClass="card">
                <padding><Insets top="20" bottom="20" left="20" right="20"/></padding>

                <Label text="👤 Form Karyawan (SuperAdmin)" styleClass="brand-title">
                    <font><Font name="System Bold" size="15"/></font>
                </Label>

                <TextField fx:id="txtId" promptText="ID Karyawan" editable="false" styleClass="input-field"/>
                <TextField fx:id="txtNama" promptText="Nama Lengkap" styleClass="input-field"/>
                <TextField fx:id="txtNoTelp" promptText="No. HP" styleClass="input-field"/>
                <TextField fx:id="txtUmur" promptText="Umur" styleClass="input-field"/>
                <TextField fx:id="txtAlamat" promptText="Alamat" styleClass="input-field"/>
                <DatePicker fx:id="dpTanggalMasuk" promptText="Tanggal Masuk" maxWidth="Infinity" styleClass="input-field"/>
                <TextField fx:id="txtUsername" promptText="Username" styleClass="input-field"/>
                <PasswordField fx:id="txtPassword" promptText="Password" styleClass="input-field"/>

                <HBox spacing="8" alignment="CENTER_LEFT">
                    <Label text="Status:" styleClass="welcome-text"/>
                    <Label fx:id="lblStatus" text="-" styleClass="brand-title"/>
                </HBox>

                <Region VBox.vgrow="ALWAYS"/>
                <TextField fx:id="txtCari" promptText="🔍 Cari karyawan..." styleClass="input-field"/>
            </VBox>

            <!-- TABLE -->
            <VBox HBox.hgrow="ALWAYS" styleClass="card">
                <padding><Insets top="15" bottom="15" left="15" right="15"/></padding>

                <TableView fx:id="tableKaryawan" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colId" text="ID Karyawan" prefWidth="90"/>
                        <TableColumn fx:id="colNama" text="Nama" prefWidth="150"/>
                        <TableColumn fx:id="colNoTelp" text="No. HP" prefWidth="110"/>
                        <TableColumn fx:id="colUmur" text="Umur" prefWidth="55"/>
                        <TableColumn fx:id="colAlamat" text="Alamat" prefWidth="150"/>
                        <TableColumn fx:id="colTglMasuk" text="Tgl Masuk" prefWidth="95"/>
                        <TableColumn fx:id="colUsername" text="Username" prefWidth="100"/>
                        <TableColumn fx:id="colStatus" text="Status" prefWidth="90"/>
                        <TableColumn fx:id="colRole" text="Role" prefWidth="90"/>
                    </columns>
                </TableView>
            </VBox>

        </HBox>
    </center>

    <bottom>
        <HBox spacing="10" alignment="CENTER_LEFT" styleClass="card">
            <padding><Insets top="15" bottom="15" left="20" right="20"/></padding>

            <Button fx:id="btnSimpan" text="Simpan" onAction="#handleSimpan"
                    styleClass="btn-primary" prefWidth="100"/>
            <Button fx:id="btnUbah" text="Ubah" onAction="#handleUbah"
                    styleClass="btn-warning" prefWidth="100"/>
            <Button fx:id="btnHapus" text="Nonaktifkan" onAction="#handleHapus"
                    styleClass="btn-danger" prefWidth="110"/>
            <Button text="Reset" onAction="#handleReset"
                    styleClass="btn-neutral" prefWidth="100"/>
        </HBox>
    </bottom>

</BorderPane>