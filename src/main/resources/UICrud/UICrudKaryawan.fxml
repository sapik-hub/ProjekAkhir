<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="ProjekAstra.Controller.Transaksi.BookingKaryawan"
            styleClass="bg-soft"
            stylesheets="@../css/villa-theme.css">

    <center>
        <HBox spacing="15">
            <padding><Insets top="0" bottom="15" left="0" right="0"/></padding>

            <!-- FORM INPUT -->
            <ScrollPane fitToWidth="true" prefWidth="300" styleClass="card" hbarPolicy="NEVER">
                <VBox spacing="10">
                    <padding><Insets top="20" bottom="20" left="20" right="20"/></padding>

                    <Label text="🧾 Form Transaksi Booking" styleClass="brand-title">
                        <font><Font name="System Bold" size="15"/></font>
                    </Label>

                    <TextField fx:id="txtIdBooking" promptText="ID Booking" editable="false" styleClass="input-field"/>

                    <Separator/>
                    <Label text="Data Penyewa" styleClass="welcome-text" style="-fx-font-weight: bold;"/>

                    <TextField fx:id="txtIdPenyewa" promptText="ID Penyewa (ketik lalu Enter)" styleClass="input-field"/>
                    <TextField fx:id="txtNamaPenyewa" promptText="Nama (otomatis)" editable="false" styleClass="input-field"/>
                    <TextField fx:id="txtNoTelp" promptText="No. Telp (otomatis)" editable="false" styleClass="input-field"/>
                    <TextField fx:id="txtUsername" promptText="Username (otomatis)" editable="false" styleClass="input-field"/>

                    <Separator/>
                    <Label text="Data Villa" styleClass="welcome-text" style="-fx-font-weight: bold;"/>

                    <ComboBox fx:id="cbVilla" promptText="Pilih Villa" maxWidth="Infinity" styleClass="input-field"/>
                    <TextField fx:id="txtKategoriVilla" promptText="Kategori Villa (otomatis)" editable="false" styleClass="input-field"/>
                    <TextField fx:id="txtHargaVilla" promptText="Harga Villa (otomatis)" editable="false" styleClass="input-field"/>
                    <TextArea fx:id="txtFasilitasVilla" promptText="Fasilitas Villa (otomatis)" editable="false"
                              prefRowCount="2" wrapText="true" styleClass="input-field"/>

                    <Separator/>
                    <Label text="Detail Booking" styleClass="welcome-text" style="-fx-font-weight: bold;"/>

                    <DatePicker fx:id="dpCheckin" promptText="Tanggal Check-In" maxWidth="Infinity" styleClass="input-field"/>
                    <DatePicker fx:id="dpCheckout" promptText="Tanggal Check-Out" maxWidth="Infinity" styleClass="input-field"/>
                    <TextField fx:id="txtJumlahTamu" promptText="Jumlah Tamu" styleClass="input-field"/>
                    <TextField fx:id="txtGrandHarga" promptText="Grand Harga (otomatis)" editable="false" styleClass="input-field"/>
                    <TextArea fx:id="txtCatatan" promptText="Catatan (opsional)" prefRowCount="2" wrapText="true" styleClass="input-field"/>
                    <ComboBox fx:id="cbStatus" promptText="Status Booking (saat ubah)" maxWidth="Infinity" styleClass="input-field"/>

                    <Region prefHeight="10"/>
                    <TextField fx:id="txtCari" promptText="🔍 Cari ID / nama / villa..." styleClass="input-field"/>
                </VBox>
            </ScrollPane>

            <!-- TABLE -->
            <VBox HBox.hgrow="ALWAYS" styleClass="card">
                <padding><Insets top="15" bottom="15" left="15" right="15"/></padding>

                <TableView fx:id="tableBooking" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colIdBooking" text="ID Booking" prefWidth="90"/>
                        <TableColumn fx:id="colIdPenyewa" text="ID Penyewa" prefWidth="90"/>
                        <TableColumn fx:id="colNama" text="Nama" prefWidth="120"/>
                        <TableColumn fx:id="colNoTelp" text="No. Telp" prefWidth="110"/>
                        <TableColumn fx:id="colUsername" text="Username" prefWidth="100"/>
                        <TableColumn fx:id="colVilla" text="Nama Villa" prefWidth="130"/>
                        <TableColumn fx:id="colKategori" text="Kategori Villa" prefWidth="110"/>
                        <TableColumn fx:id="colFasilitas" text="Fasilitas" prefWidth="180"/>
                        <TableColumn fx:id="colHargaVilla" text="Harga Villa" prefWidth="100"/>
                        <TableColumn fx:id="colCheckin" text="Check-In" prefWidth="90"/>
                        <TableColumn fx:id="colCheckout" text="Check-Out" prefWidth="90"/>
                        <TableColumn fx:id="colTamu" text="Jumlah Tamu" prefWidth="90"/>
                        <TableColumn fx:id="colGrandHarga" text="Grand Harga" prefWidth="110"/>
                        <TableColumn fx:id="colStatus" text="Status" prefWidth="130"/>
                    </columns>
                </TableView>
            </VBox>
        </HBox>
    </center>

    <bottom>
        <HBox spacing="10" alignment="CENTER_LEFT" styleClass="card">
            <padding><Insets top="15" bottom="15" left="20" right="20"/></padding>

            <Button fx:id="btnSimpan" text="Simpan" onAction="#handleSimpan"
                    styleClass="btn-primary" prefWidth="100"/>
            <Button fx:id="btnUbah" text="Ubah" onAction="#handleUbah"
                    styleClass="btn-warning" prefWidth="100"/>
            <Button fx:id="btnHapus" text="Batalkan" onAction="#handleHapus"
                    styleClass="btn-danger" prefWidth="100"/>
            <Button text="Reset" onAction="#handleReset"
                    styleClass="btn-neutral" prefWidth="100"/>
        </HBox>
    </bottom>

</BorderPane>
