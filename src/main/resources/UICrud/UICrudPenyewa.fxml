<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="ProjekAstra.Controller.Master.CrudPenyewa"
            styleClass="bg-soft"
            stylesheets="@../css/villa-theme.css">

    <center>
        <HBox spacing="15">
            <padding><Insets top="0" bottom="15" left="0" right="0"/></padding>

            <VBox spacing="12" prefWidth="280" styleClass="card">
                <padding><Insets top="20" bottom="20" left="20" right="20"/></padding>

                <Label text="🧑 Form Penyewa" styleClass="brand-title">
                    <font><Font name="System Bold" size="15"/></font>
                </Label>

                <TextField fx:id="txtId" promptText="ID Penyewa" editable="false" styleClass="input-field"/>
                <TextField fx:id="txtNama" promptText="Nama" styleClass="input-field"/>
                <TextField fx:id="txtNoTelp" promptText="No. Telp" styleClass="input-field"/>
                <TextField fx:id="txtNikKtp" promptText="NIK KTP (16 digit)"
                           onKeyTyped="#handleNikOnlyNumber" styleClass="input-field"/>
                <DatePicker fx:id="dpTglLahir" promptText="Tanggal Lahir" maxWidth="Infinity" styleClass="input-field"/>
                <TextField fx:id="txtAlamat" promptText="Alamat" styleClass="input-field"/>
                <TextField fx:id="txtUsername" promptText="Username" styleClass="input-field"/>
                <PasswordField fx:id="txtPassword" promptText="Password" styleClass="input-field"/>

                <Region VBox.vgrow="ALWAYS"/>
                <TextField fx:id="txtCari" promptText="🔍 Cari nama / ID penyewa..." styleClass="input-field"/>
            </VBox>

            <VBox HBox.hgrow="ALWAYS" styleClass="card">
                <padding><Insets top="15" bottom="15" left="15" right="15"/></padding>

                <TableView fx:id="tablePenyewa" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colId" text="ID Penyewa" prefWidth="90"/>
                        <TableColumn fx:id="colNama" text="Nama" prefWidth="150"/>
                        <TableColumn fx:id="colNoTelp" text="No. Telp" prefWidth="120"/>
                        <TableColumn fx:id="colNikKtp" text="NIK KTP" prefWidth="150"/>
                        <TableColumn fx:id="colTglLahir" text="Tanggal Lahir" prefWidth="110"/>
                        <TableColumn fx:id="colAlamat" text="Alamat" prefWidth="180"/>
                        <TableColumn fx:id="colUsername" text="Username" prefWidth="120"/>
                    </columns>
                </TableView>
            </VBox>
        </HBox>
    </center>

    <bottom>
        <HBox spacing="10" alignment="CENTER_LEFT" styleClass="card">
            <padding><Insets top="15" bottom="15" left="20" right="20"/></padding>

            <Button fx:id="btnSimpan" text="Simpan" onAction="#handleSimpan"
                    styleClass="btn-primary" prefWidth="100"/>
            <Button fx:id="btnUbah" text="Ubah" onAction="#handleUbah"
                    styleClass="btn-warning" prefWidth="100"/>
            <Button fx:id="btnHapus" text="Hapus" onAction="#handleHapus"
                    styleClass="btn-danger" prefWidth="100"/>
            <Button text="Reset" onAction="#handleReset"
                    styleClass="btn-neutral" prefWidth="100"/>
        </HBox>
    </bottom>

</BorderPane>